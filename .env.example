# Know Your Bite — environment variables
# Copy to `.env` for local use. On Replit, set these in BOTH the Workspace
# Secrets and the Deployment Secrets. The server validates these at boot
# (packages/shared env schema) and exits with a clear message if any required
# one is missing or invalid — see IMPLEMENTATION-ROADMAP.md M0.5.

# --- Required ---
# Postgres connection string. On Replit this is auto-provisioned when you add
# the PostgreSQL module; use the POOLED (`-pooler`) connection string.
DATABASE_URL="postgresql://user:password@host-pooler.region.neon.tech/dbname?sslmode=require"

# Secret used to sign session cookies. Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET="change-me-to-a-long-random-string"

# --- Required before their feature ships (optional for the M0 skeleton) ---
# Anthropic API key (AI features — Milestone 2+).
ANTHROPIC_API_KEY=""

# USDA FoodData Central API key from https://fdc.nal.usda.gov/api-key-signup.html
# (recipe library — Milestone 3+). Must NOT be the shared "DEMO_KEY".
USDA_API_KEY=""

# --- Optional ---
# Error monitoring (Sentry). Leave blank to disable.
SENTRY_DSN=""

# Public base URL of the app (used in verification/reset emails). On Replit this
# is your Deployment URL, e.g. https://your-repl.replit.app
APP_URL="http://localhost:5000"

# Port the server listens on. Replit maps 5000 -> public :80.
PORT="5000"

# NODE_ENV is set by the run/deploy commands (development | production | test).
